# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/superintendent_finder
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/superintendent_finder

# Redis
REDIS_URL=redis://localhost:6379/0

# Mailgun
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_SENDER_EMAIL=outreach@yourdomain.com
MAILGUN_WEBHOOK_SIGNING_KEY=your-webhook-signing-key

# Application
APP_NAME=Superintendent Finder
APP_PHYSICAL_ADDRESS=123 Main St, Suite 100, Anytown, ST 12345
SECRET_KEY=change-me-to-a-random-secret-key

# Email Limits
DAILY_EMAIL_LIMIT=100
WARMUP_PHASE=true
